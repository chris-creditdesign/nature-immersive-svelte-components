{
	"name": "nature-immersive-svelte-components",
	"version": "0.5.23",
	"description": "Collection of svelte components to build nature immersive articles",
	"type": "module",
	"svelte": "src/index.js",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"svelte": "./src/index.js",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "vite build",
		"build:css": "sass ./src/scss/index.scss ./static/css/light.css && sass ./src/scss/index-dark.scss ./static/css/dark.css",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"prettier": "prettier --write src/components/**/*",
		"stylelint": "stylelint --fix src/components/**/* static/css/**/*.css",
		"lint": "eslint src/",
		"test": "vitest",
		"prepublishOnly": "npm run build",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"author": "chris-creditdesign",
	"license": "ISC",
	"keywords": [
		"svelte"
	],
	"files": [
		"src",
		"dist",
		"static/css"
	],
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@storybook/addon-essentials": "^8.6.14",
		"@storybook/addon-links": "^8.6.18",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/svelte": "^8.6.18",
		"@storybook/svelte-vite": "^8.6.18",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"creditdesign-svelte-components": "^2.0.6",
		"eslint": "^9.39.4",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"postcss-html": "^1.8.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"storybook": "^8.6.18",
		"storybook-dark-mode": "^4.0.2",
		"stylelint": "^16.26.1",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-standard": "^36.0.1",
		"stylelint-order": "^6.0.4",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"svelte-eslint-parser": "^1.6.1",
		"typescript": "^6.0.3",
		"vite": "^6.4.2",
		"vitest": "^4.1.7"
	}
}